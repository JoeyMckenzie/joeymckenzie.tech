        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "concurrently": "^9.0.1",
        "input-otp": "^1.4.2",
        "laravel-vite-plugin": "^3.1.0",
        "lucide-react": "^1.14.0",
        "mermaid": "^11.15.0",
        "motion": "^12.38.0",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "simple-icons": "^16.19.0",
