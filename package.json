{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "name": "website",
    "scripts": {
        "build": "tsc && vite build",
        "build:ssr": "tsc && vite build && vite build --ssr",
        "dev": "vite",
        "preview:ssr": "npm run build:ssr && php artisan inertia:start-ssr",
        "fmt": "oxfmt",
        "fmt:check": "oxfmt --check",
        "lint": "oxlint",
        "lint:check": "oxlint --fix",
        "types:check": "tsc --noEmit"
    },
    "dependencies": {
